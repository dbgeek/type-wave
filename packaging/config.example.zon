// type-wave settings (wayfinder #16; menu-bar editing #34).
//
// Copy to ~/.config/type-wave/config.zon and edit. EVERY field is optional — omit
// any one to keep its default (the value shown here). An absent or malformed file
// falls back to all defaults, so type-wave still starts.
//
// This file stays canonical alongside the menu bar: the daemon's status-item menu
// rewrites single fields in place (your comments survive), and hand-edits are picked
// up the next time the menu opens (or on restart) — no file watcher, no daemon fight.
//
// The OpenAI secret does NOT live here. It lives in the login keychain (#33): use the
// menu's "Set API Key…", or run `~/.local/bin/type-wave --set-key`. A foreground
// `nix develop` run uses the exported OPENAI_API_KEY env var instead (dev override).
.{
    // Selected Transcription Backend. OpenAI remains the default; local uses only the
    // verified Model Installation and never falls back across this privacy boundary.
    .transcription_backend = .openai,

    // Which held key starts/ends an Utterance:
    //   .right_option / .left_option  — proven live (wayfinder #9)
    //   .globe                        — the Fn / 🌐 key; observation is compile-verified
    //                                   only and may clash with macOS's own Fn→Dictation
    //                                   binding (wayfinder #6). Opt in at your own risk.
    .talk_key = .right_option,

    // OpenAI transcription knobs. Strings, so you can A/B a different model with no
    // rebuild (wayfinder #11) — e.g. .model = "gpt-4o-mini-transcribe" (note: that
    // model supports prompt biasing but loses live Partial Transcripts).
    // .language = "" means auto-detect (the field is omitted from the session).
    .model = "gpt-realtime-whisper",
    .language = "en",
    .delay = "low",

    // Input noise reduction: .near_field (headset/handheld), .far_field (laptop mic),
    // or .off (sends none).
    .noise_reduction = .near_field,

    // How the Final Transcript lands at the cursor:
    //   .paste     — clipboard swap + ⌘V (primary; best for terminals/Electron)
    //   .keystroke — synthetic Unicode typing (fallback)
    .insertion = .paste,

    // Milliseconds between writing the pasteboard and posting ⌘V (paste insertion
    // only). The pasteboard write is synchronous, so this only guards slow target
    // apps — raise it (espanso used 100) if a target pastes the OLD clipboard.
    .pre_paste_ms = 25,

    // Show the floating overlay HUD (wayfinder #22/#27): a silent bottom-centre pill —
    // a scrolling red waveform of your live mic level while you hold the Talk Key,
    // three bouncing green dots until the Insertion resolves, no text ever. When on, it
    // takes over the start/stop feedback (the pill IS the signal), keeping only the
    // error chime. Set false for sound-only feedback (all three chimes). A headless run
    // with no display degrades to sound-only automatically.
    .overlay = true,
}
